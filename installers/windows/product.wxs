<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://schemas.microsoft.com/wix/2006/wi">
  <Product
      Id="*"
      Name="buttre"
      Language="1033"
      Version="$(var.Version)"
      Manufacturer="buttre project"
      UpgradeCode="8C5B151A-3EAC-4313-ACEA-E85BACB1CA82">
    <!--
      UPGRADE GUID: 8C5B151A-3EAC-4313-ACEA-E85BACB1CA82
      DO NOT CHANGE THIS GUID ACROSS VERSIONS — Windows uses it to detect "same product, newer version".
      Changing it forces a parallel install instead of an in-place upgrade, orphaning registry entries.

      TSF CLSID: E6B8A6C0-1234-5678-9ABC-DEF012345678
      Must match CLSID_buttre_TEXT_SERVICE in crates/buttre-platform/src/platforms/windows/tsf/mod.rs.

      TSF Profile GUID: B7447743-7652-4AB6-8D82-250D935EBCC0
      Language Profile GUID for vi-VN (LCID 0x042A). Choose once, never change.
    -->

    <Package InstallerVersion="500"
             Compressed="yes"
             InstallScope="perMachine"
             Description="buttre Vietnamese IME for Windows"
             Manufacturer="buttre project" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of buttre is already installed." />
    <MediaTemplate EmbedCab="yes" />

    <Feature Id="MainFeature" Title="buttre" Level="1">
      <ComponentRef Id="CoreBinary" />
      <ComponentRef Id="TsfDll" />
      <ComponentRef Id="TsfProfile" />
      <ComponentGroupRef Id="KeyboardConfigs" />
      <?ifdef IncludeNomDb ?>
        <ComponentRef Id="NomDb" />
      <?endif ?>
    </Feature>

    <Directory Id="TARGETDIR" Name="SourceDir">
      <Directory Id="ProgramFiles64Folder">
        <Directory Id="INSTALLDIR" Name="buttre">

          <Component Id="CoreBinary" Guid="*">
            <File Id="ButtreExe"
                  Source="$(var.CargoTargetBinDir)\buttre.exe"
                  KeyPath="yes" />
          </Component>

          <Component Id="TsfDll" Guid="*">
            <File Id="ButtrePlatformDll"
                  Source="$(var.CargoTargetBinDir)\buttre_platform.dll"
                  KeyPath="yes" />

            <!-- COM InprocServer32 registration so Windows can load the TSF DLL -->
            <RegistryKey Root="HKLM" Key="SOFTWARE\Classes\CLSID\{E6B8A6C0-1234-5678-9ABC-DEF012345678}">
              <RegistryValue Type="string" Value="buttre Text Service" />
              <RegistryKey Key="InProcServer32">
                <RegistryValue Type="string" Value="[INSTALLDIR]buttre_platform.dll" />
                <RegistryValue Type="string" Name="ThreadingModel" Value="Apartment" />
              </RegistryKey>
            </RegistryKey>
          </Component>

          <!-- TsfProfile: registry-only component, KeyPath on first value -->
          <Component Id="TsfProfile" Guid="*">
            <RegistryKey Root="HKLM"
                         Key="SOFTWARE\Microsoft\CTF\TIP\{E6B8A6C0-1234-5678-9ABC-DEF012345678}">
              <RegistryValue Type="string" Value="" KeyPath="yes" />
              <!-- Language profile for vi-VN (LCID 0x042A) -->
              <RegistryKey Key="LanguageProfile\0x0000042A\{B7447743-7652-4AB6-8D82-250D935EBCC0}">
                <RegistryValue Type="string" Name="Description" Value="buttre Vietnamese IME" />
                <RegistryValue Type="integer" Name="Enable" Value="1" />
              </RegistryKey>
            </RegistryKey>
          </Component>

          <Directory Id="KeyboardsDir" Name="keyboards">
            <Component Id="Kb_Cham" Guid="*">
              <File Source="$(var.CargoTargetBinDir)\keyboards\cham.toml" KeyPath="yes" />
            </Component>
            <Component Id="Kb_ChamAkharThrah" Guid="*">
              <File Source="$(var.CargoTargetBinDir)\keyboards\cham_akhar_thrah.toml" KeyPath="yes" />
            </Component>
            <Component Id="Kb_Hmong" Guid="*">
              <File Source="$(var.CargoTargetBinDir)\keyboards\hmong.toml" KeyPath="yes" />
            </Component>
            <Component Id="Kb_Khmer" Guid="*">
              <File Source="$(var.CargoTargetBinDir)\keyboards\khmer.toml" KeyPath="yes" />
            </Component>
            <Component Id="Kb_MuongTayNung" Guid="*">
              <File Source="$(var.CargoTargetBinDir)\keyboards\muong_tay_nung.toml" KeyPath="yes" />
            </Component>
            <Component Id="Kb_TayNguyen" Guid="*">
              <File Source="$(var.CargoTargetBinDir)\keyboards\taynguyen.toml" KeyPath="yes" />
            </Component>
            <Component Id="Kb_Thai" Guid="*">
              <File Source="$(var.CargoTargetBinDir)\keyboards\thai.toml" KeyPath="yes" />
            </Component>
          </Directory>

          <?ifdef IncludeNomDb ?>
            <Component Id="NomDb" Guid="*">
              <File Id="NomDbFile"
                    Source="$(var.CargoTargetBinDir)\buttre_nom.db"
                    KeyPath="yes" />
            </Component>
          <?endif ?>

        </Directory>
      </Directory>
    </Directory>

    <ComponentGroup Id="KeyboardConfigs">
      <ComponentRef Id="Kb_Cham" />
      <ComponentRef Id="Kb_ChamAkharThrah" />
      <ComponentRef Id="Kb_Hmong" />
      <ComponentRef Id="Kb_Khmer" />
      <ComponentRef Id="Kb_MuongTayNung" />
      <ComponentRef Id="Kb_TayNguyen" />
      <ComponentRef Id="Kb_Thai" />
    </ComponentGroup>

  </Product>
</Wix>
