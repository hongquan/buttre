# Normalize line endings; shell scripts must stay LF to keep shebangs runnable.
* text=auto
*.sh text eol=lf
*.bat text eol=crlf
*.ps1 text eol=crlf

*.db binary
*.ico binary
*.png binary
*.rc binary

# Attested-syllable dataset: source list + license must stay LF-only so the
# generator's line-based parsing (and its Trojan-source guard) is stable
# across OSes; the generated bitset is pinned to LF for reproducible diffs.
crates/buttre-engine/data/* text eol=lf
crates/buttre-engine/src/pipeline/attested_data.rs text eol=lf
